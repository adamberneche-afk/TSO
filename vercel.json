{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "tais_frontend",
  "framework": "vite",
  "buildCommand": "cd tais_frontend && npm run build",
  "outputDirectory": "tais_frontend/dist",
  "installCommand": "cd tais_frontend && npm install",
  "devCommand": "cd tais_frontend && npm run dev",
  "regions": ["iad1"],
  "env": {
    "VITE_REGISTRY_URL": "https://tso.onrender.com",
    "VITE_RPC_URL": "https://cloudflare-eth.com",
    "VITE_GENESIS_CONTRACT": "0x11B3EfbF04F0bA505F380aC20444B6952970AdA6"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
