# TAIS Environment Configuration
# =============================================  
# REQUIRED: AI Provider  
# =============================================  
# Default Anthropic API Key (for System AI mode)  
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# =============================================  
# REQUIRED: Blockchain RPC  
# =============================================  
# Ethereum RPC endpoint for Genesis NFT verification  
# Get a free key from: https://www.alchemy.com or https://infura.io  
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# =============================================  
# OPTIONAL: Development  
# =============================================  
# Enable mock profile for testing (bypasses NFT gate)  
# Values: true | false  
DEV_MODE=false

# Node environment  
NODE_ENV=production
