generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Note: This schema supports dual-database architecture
// DATABASE_URL is used by Prisma CLI for migrations
// RAG_DATABASE_URL and SKILLS_DATABASE_URL are used by the application at runtime
// For migration commands, set DATABASE_URL to the target database (tais-rag or tais_registry)

model Skill {
  id          String   @id @default(uuid())
  skillHash   String   @unique @map("skill_hash")
  name        String
  version     String
  description String?
  author      String   // Wallet address
  
  // IPFS CIDs
  manifestCid String   @map("manifest_cid")
  packageCid  String?  @map("package_cid")
  
  // On-chain data
  contractAddress String? @map("contract_address")
  tokenId         String? @map("token_id")
  
  // Metadata
  permissions   Json     // Stored as JSON
  trustScore    Float    @default(0) @map("trust_score")
  downloadCount Int      @default(0) @map("download_count")
  
  // Status
  status      SkillStatus @default(PENDING)
  isBlocked   Boolean     @default(false) @map("is_blocked")
  blockedAt   DateTime?   @map("blocked_at")
  blockedReason String?   @map("blocked_reason")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  audits    Audit[]
  categories SkillCategory[]
  tags      SkillTag[]
  
  @@index([skillHash])
  @@index([author])
  @@index([status])
  @@index([trustScore])
  @@map("skills")
}

model Audit {
  id          String   @id @default(uuid())
  skillId     String   @map("skill_id")
  skill       Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  
  auditor     String   // Wallet address
  auditorNft  String?  @map("auditor_nft") // NFT token ID
  
  status      AuditStatus
  findings    Json?    // Array of YARA findings
  signature   String   // Cryptographic signature
  
  // On-chain verification
  txHash      String?  @map("tx_hash")
  verifiedAt  DateTime? @map("verified_at")
  
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@index([skillId])
  @@index([auditor])
  @@index([status])
  @@map("audits")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  
  skills      SkillCategory[]
  
  @@map("categories")
}

model Tag {
  id    String @id @default(uuid())
  name  String @unique
  
  skills SkillTag[]
  
  @@map("tags")
}

model SkillCategory {
  skillId    String   @map("skill_id")
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  @@id([skillId, categoryId])
  @@map("skill_categories")
}

model SkillTag {
  skillId String @map("skill_id")
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  tagId   String @map("tag_id")
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@id([skillId, tagId])
  @@map("skill_tags")
}

// BLOCKER-1 FIX: Updated ApiKey model to match service implementation
model ApiKey {
  id          String    @id @default(uuid())
  keyHash     String    @unique @map("key_hash")
  walletAddress String  @map("wallet_address")
  name        String
  permissions String[]  // PostgreSQL array type
  
  // Rate limiting
  rateLimit   Int       @default(1000) @map("rate_limit")
  requestCount Int      @default(0) @map("request_count")
  
  // Status
  revokedAt   DateTime? @map("revoked_at")
  expiresAt   DateTime? @map("expires_at")
  
  createdAt   DateTime  @default(now()) @map("created_at")
  lastUsedAt  DateTime? @map("last_used_at")
  
  @@index([keyHash])
  @@index([walletAddress])
  @@map("api_keys")
}

// BLOCKER-1 FIX: New AuthNonce model for replay attack prevention
// Squad Epsilon MEDIUM-2 Fix: Added unique constraint to prevent duplicates
model AuthNonce {
  id            String   @id @default(uuid())
  walletAddress String   @map("wallet_address")
  nonce         String
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")
  
  @@unique([walletAddress, nonce])
  @@index([walletAddress])
  @@index([nonce])
  @@map("auth_nonces")
}

enum SkillStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum AuditStatus {
  SAFE
  SUSPICIOUS
  MALICIOUS
}

// BLOCKER-1 FIX: Removed old ApiTier enum (no longer used)

model SecurityScan {
  id          String   @id @default(uuid())
  skillHash   String   @map("skill_hash")
  
  severity    String   // 'safe', 'suspicious', 'malicious'
  findings    Json     // Array of YARA findings
  summary     Json     // Scan summary statistics
  
  scanDuration  Int    @map("scan_duration") // milliseconds
  scannedFiles  Int    @map("scanned_files")
  scannedBytes  Int    @map("scanned_bytes")
  
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@index([skillHash])
  @@index([severity])
  @@index([createdAt])
  @@map("security_scans")
}

// DEPLOYMENT FIX: TokenBlacklist model for JWT logout functionality
model TokenBlacklist {
  id            String   @id @default(uuid())
  tokenHash     String   @unique @map("token_hash")
  walletAddress String   @map("wallet_address")
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")
  
  @@index([tokenHash])
  @@index([walletAddress])
  @@map("token_blacklist")
}

// Genesis Holder Agent Configurations
model AgentConfiguration {
  id          String   @id @default(uuid())
  walletAddress String @map("wallet_address")
  
  // NFT ownership verification
  nftTokenId  String   @map("nft_token_id")
  nftContractAddress String @map("nft_contract_address")
  verifiedAt  DateTime @map("verified_at")
  
  // Configuration data
  name        String
  description String?
  configData  Json     @map("config_data") // The full agent configuration JSON
  
  // Hybrid personality system (v2.7.0)
  personalityMd      String?  @map("personality_md")       // Markdown personality (flexible, LLM-friendly)
  personalityVersion Int      @default(1) @map("personality_version") // Version for cache invalidation
  
  // Metadata
  version     Int      @default(1)
  isActive    Boolean  @default(true) @map("is_active")
  
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@index([walletAddress])
  @@index([nftTokenId])
  @@index([isActive])
  @@map("agent_configurations")
}

// ============================================
// Configuration Versioning (v2.7.7)
// ============================================

model ConfigurationVersion {
  id            String   @id @default(uuid())
  configId      String   @map("config_id")
  walletAddress String   @map("wallet_address")
  
  // Version info
  version       Int
  versionNote   String?  @map("version_note") // Optional changelog
  
  // Compressed snapshot (gzip)
  configSnapshot Json    @map("config_snapshot") // Full config JSON
  personalityMd String?  @map("personality_md")
  
  // Tier-based retention
  tier          String   @default("bronze") // bronze, silver, gold
  
  // Timestamps
  createdAt     DateTime @default(now()) @map("created_at")
  expiresAt     DateTime? @map("expires_at") // For auto-cleanup
  
  @@unique([configId, version])
  @@index([walletAddress])
  @@index([configId])
  @@index([expiresAt])
  @@map("configuration_versions")
}

// ============================================
// RAG (Retrieval-Augmented Generation) Models
// ============================================

// RAG Document - Encrypted document storage for Public RAG
model RAGDocument {
  id              String   @id @default(uuid())
  
  // Owner information
  walletAddress   String   @map("wallet_address")
  ownerPublicKey  String   @map("owner_public_key")
  
  // Encrypted content (E2EE)
  encryptedData       String   @map("encrypted_data") // Base64 encrypted content
  encryptedMetadata   String   @map("encrypted_metadata") // Base64 encrypted metadata
  iv                  String   // Base64 IV
  salt                String   // Base64 salt for key derivation
  
  // Document properties
  title           String?  // Optional - may be encrypted in metadata
  isPublic        Boolean  @default(false) @map("is_public")
  tags            String[] // PostgreSQL array
  
  // Storage info
  size            Int      // Size in bytes
  chunkCount      Int      @map("chunk_count")
  storageUrl      String?  @map("storage_url") // S3/R2 URL
  
  // Access control
  allowedViewers  String[] @map("allowed_viewers") // Array of public keys
  
  // Engagement metrics
  downloadCount   Int      @default(0) @map("download_count")
  popularityScore Float    @default(0) @map("popularity_score")
  
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  // Relations
  chunks          RAGChunk[]
  
  @@index([walletAddress])
  @@index([isPublic])
  @@index([tags])
  @@index([createdAt])
  @@index([popularityScore])
  @@map("rag_documents")
}

// RAG Chunk - Individual chunks of documents with embedding hashes
model RAGChunk {
  id              String   @id @default(uuid())
  
  // Parent document
  documentId      String   @map("document_id")
  document        RAGDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  
  // Encrypted content
  encryptedContent String  @map("encrypted_content") // Base64
  iv              String   // Base64 IV
  
  // Indexing
  index           Int      // Position in document
  embeddingHash   String   @map("embedding_hash") // SHA-256 hash for search (privacy-preserving)
  
  // Size
  size            Int      // Size in bytes
  
  @@index([documentId])
  @@index([embeddingHash])
  @@map("rag_chunks")
}

// RAG User Usage Tracking - Per-user quota enforcement
model RAGUserUsage {
  id              String   @id @default(uuid())
  
  walletAddress   String   @unique @map("wallet_address")
  
  // Storage usage
  storageUsed     Int      @default(0) @map("storage_used") // Bytes
  
  // Monthly embeddings (resets monthly)
  embeddingsThisMonth Int  @default(0) @map("embeddings_this_month")
  lastResetMonth  DateTime @default(now()) @map("last_reset_month")
  
  // Daily queries (resets daily)
  queriesToday    Int      @default(0) @map("queries_today")
  lastResetDay    DateTime @default(now()) @map("last_reset_day")
  
  // App connections
  appConnectionsUsed Int   @default(0) @map("app_connections_used")
  
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@index([walletAddress])
  @@map("rag_user_usage")
}

// RAG Public Keys - Store user public keys for sharing
model RAGPublicKey {
  id              String   @id @default(uuid())
  
  walletAddress   String   @unique @map("wallet_address")
  publicKey       String   @unique
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@index([walletAddress])
  @@index([publicKey])
  @@map("rag_public_keys")
}

// RAG App Connections - Track app integrations
model RAGAppConnection {
  id              String   @id @default(uuid())
  
  walletAddress   String   @map("wallet_address")
  appId           String   @map("app_id")
  appName         String   @map("app_name")
  
  // OAuth tokens (encrypted)
  encryptedAccessToken  String @map("encrypted_access_token")
  encryptedRefreshToken String? @map("encrypted_refresh_token")
  tokenExpiresAt        DateTime? @map("token_expires_at")
  
  // Permissions
  permissions     String[] // ['rag:read', 'rag:write']
  
  // Status
  isActive        Boolean  @default(true) @map("is_active")
  revokedAt       DateTime? @map("revoked_at")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@unique([walletAddress, appId])
  @@index([walletAddress])
  @@index([appId])
  @@map("rag_app_connections")
}

// RAG Audit Log - Track all RAG operations (for compliance/debugging)
model RAGAuditLog {
  id              String   @id @default(uuid())
  
  walletAddress   String   @map("wallet_address")
  action          String   // 'upload', 'search', 'download', 'share', 'delete'
  
  // Target (if applicable)
  documentId      String?  @map("document_id")
  
  // Metadata
  queryHash       String?  @map("query_hash") // Hashed query for privacy
  resultCount     Int?     @map("result_count")
  
  // Performance
  duration        Int      // Milliseconds
  
  // IP and user agent (for security)
  ipAddress       String?  @map("ip_address")
  userAgent       String?  @map("user_agent")
  
  createdAt       DateTime @default(now()) @map("created_at")
  
  @@index([walletAddress])
  @@index([action])
  @@index([createdAt])
  @@map("rag_audit_logs")
}

// ============================================
// Guided Discovery - Interview-driven agent creation
// ============================================

model GuidedDiscoverySession {
  id            String   @id @default(uuid())
  walletAddress String   @map("wallet_address")
  
  // Progress tracking
  currentStep   Int      @default(1) @map("current_step")
  responses     Json     // { questionId: answer }
  
  // Status
  status        String   @default("in_progress") // 'in_progress', 'completed', 'abandoned'
  
  // Timestamps
  startedAt     DateTime @default(now()) @map("started_at")
  completedAt  DateTime? @map("completed_at")
  
  @@index([walletAddress])
  @@index([status])
  @@index([startedAt])
  @@map("guided_discovery_sessions")
}

// ============================================
// Analytics - SDK Integration & Usage Tracking
// ============================================

model SDKAnalyticsEvent {
  id            String   @id @default(uuid())
  
  // Event categorization
  eventType     String   @map("event_type") // 'session_started', 'session_completed', 'error_encountered', 'feature_used', 'api_call'
  source        String   // 'sdk_assistant', 'ct0_agent', 'api'
  
  // User identification
  walletAddress String?  @map("wallet_address")
  sessionId     String?  @map("session_id")
  
  // Event data
  metadata      Json     // { feature: 'upload', error: 'timeout', ... }
  duration      Int?     // Milliseconds (for timing events)
  
  // Error tracking
  errorType    String?  @map("error_type")
  errorMessage String?  @map("error_message")
  
  // Location/context
  ipAddress     String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  
  // Timestamps
  createdAt     DateTime @default(now()) @map("created_at")
  
  @@index([eventType])
  @@index([walletAddress])
  @@index([sessionId])
  @@index([source])
  @@index([createdAt])
  @@map("sdk_analytics_events")
}

// CTO Agent Project Tracking
model CTOAgentProject {
  id            String   @id @default(uuid())
  walletAddress String   @map("wallet_address")
  
  // Project info
  name          String
  description   String?
  
  // Phase tracking
  currentPhase  String   @default("planning") @map("current_phase") // 'planning', 'architecture', 'development', 'testing', 'launch'
  
  // Pain points and blockers
  painPoints    Json     @default("[]") // [{ area: 'security', description: '...', resolved: false }]
  blockers      Json     @default("[]") // [{ description: '...', resolved: false }]
  
  // Timestamps
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  completedAt   DateTime? @map("completed_at")
  
  @@index([walletAddress])
  @@index([currentPhase])
  @@index([createdAt])
  @@map("cto_agent_projects")
}

// CTO Knowledge Base - Community Insights
model CTOInsight {
  id            String   @id @default(uuid())
  
  // Content
  title        String
  content      String
  category     String   // 'value-prop', 'customer-pain', 'technical', 'architecture', 'lessons-learned'
  
  // Metadata
  walletAddress String?  @map("wallet_address") // Creator (optional for anon)
  upvotes      Int      @default(0)
  
  // Status: draft, pending_review, published
  status       String   @default("draft")
  
  // Timestamps
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@map("cto_insights")
}

// Weekly Insights Report (generated)
model WeeklyInsightsReport {
  id            String   @id @default(uuid())
  
  // Report period
  weekStart     DateTime @map("week_start")
  weekEnd       DateTime @map("week_end")
  
  // Report data
  reportData    Json     @map("report_data")
  
  // Metrics summary
  sessionsStarted Int    @default(0) @map("sessions_started")
  sessionsCompleted Int @default(0) @map("sessions_completed")
  errorsEncountered Int @default(0) @map("errors_encountered")
  
  // Top insights
  topPainPoints    Json     @default("[]") @map("top_pain_points")
  topErrors        Json     @default("[]") @map("top_errors")
  suggestions      Json     @default("[]")
  
  // Status
  generatedAt     DateTime @default(now()) @map("generated_at")
  sentAt          DateTime? @map("sent_at")
  emailStatus     String   @default("pending") @map("email_status") // 'pending', 'sent', 'failed'
  
  @@index([weekStart])
  @@index([emailStatus])
  @@map("weekly_insights_reports")
}

// ============================================
// Memory System Reports (v3.2.0)
// ============================================

// User's memory report preferences
model MemoryReportPreferences {
  id              String   @id @default(uuid())
  walletAddress   String   @unique @map("wallet_address")
  
  // Frequency preference
  reportFrequency String   @default("weekly") @map("report_frequency") // 'weekly', 'biweekly', 'monthly', 'never'
  
  // What to include
  includeDriftStats       Boolean @default(true) @map("include_drift_stats")
  includeUsagePatterns    Boolean @default(true) @map("include_usage_patterns")
  includeAppUsage         Boolean @default(true) @map("include_app_usage")
  includeRagPools        Boolean @default(true) @map("include_rag_pools")
  includeAlignmentIndex   Boolean @default(true) @map("include_alignment_index")
  
  // Notification settings
  notifyOnFlag      Boolean @default(true) @map("notify_on_flag")
  notifyOnDrift     Boolean @default(true) @map("notify_on_drift")
  
  // Last report sent
  lastReportSentAt DateTime? @map("last_report_sent_at")
  
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  
  @@index([walletAddress])
  @@map("memory_report_preferences")
}

// Memory report for each user
model MemoryReport {
  id              String   @id @default(uuid())
  walletAddress   String   @map("wallet_address")
  
  // Report period
  periodStart     DateTime @map("period_start")
  periodEnd       DateTime @map("period_end")
  
  // Alignment index (0-100)
  alignmentIndex  Float    @default(50.0) @map("alignment_index")
  
  // Drift statistics
  driftScore      Float    @default(0.0) @map("drift_score")
  driftEvents     Int      @default(0) @map("drift_events")
  driftTrend      String   @default("stable") @map("drift_trend") // 'improving', 'stable', 'declining'
  
  // Usage patterns
  totalSessions   Int      @default(0) @map("total_sessions")
  avgSessionDuration Float @default(0.0) @map("avg_session_duration")
  messagesExchanged Int   @default(0) @map("messages_exchanged")
  
  // App usage
  appUsage        Json     @default("{}") @map("app_usage") // { "conversation": 10, "rag": 5, ... }
  
  // RAG pools
  ragQueries      Int      @default(0) @map("rag_queries")
  ragPoolUsage    Json     @default("{}") @map("rag_pool_usage") // { "public": 20, "private": 5 }
  
  // Memory stats
  memoriesCreated Int     @default(0) @map("memories_created")
  memoriesPromoted Int     @default(0) @map("memories_promoted")
  coreMemories    Int      @default(0) @map("core_memories")
  
  // Flags
  isFlagged       Boolean  @default(false) @map("is_flagged")
  flagReason      String?  @map("flag_reason")
  flagSeverity    String?  @map("flag_severity") // 'low', 'medium', 'high'
  
  // Raw data (kept for debugging, not sent to user)
  rawData         Json?    @map("raw_data")
  
  createdAt       DateTime @default(now()) @map("created_at")
  
  @@index([walletAddress])
  @@index([periodStart])
  @@index([isFlagged])
  @@map("memory_reports")
}

// Aggregated anonymized stats for admin view
model MemoryReportAggregate {
  id              String   @id @default(uuid())
  
  // Aggregate period
  periodStart     DateTime @map("period_start")
  periodEnd       DateTime @map("period_end")
  
  // Aggregate stats (all users, anonymized)
  totalUsers      Int      @default(0) @map("total_users")
  
  // Alignment index distribution
  avgAlignmentIndex Float  @default(50.0) @map("avg_alignment_index")
  medianAlignmentIndex Float @default(50.0) @map("median_alignment_index")
  alignmentIndexStdDev Float @default(0.0) @map("alignment_index_std_dev")
  
  // Percentiles
  alignmentP25    Float    @default(0.0) @map("alignment_p25")
  alignmentP50    Float    @default(0.0) @map("alignment_p50")
  alignmentP75    Float    @default(0.0) @map("alignment_p75")
  alignmentP90    Float    @default(0.0) @map("alignment_p90")
  alignmentP95    Float    @default(0.0) @map("alignment_p95")
  alignmentP99    Float    @default(0.0) @map("alignment_p99")
  
  // Drift distribution
  avgDriftScore   Float    @default(0.0) @map("avg_drift_score")
  highDriftUsers  Int      @default(0) @map("high_drift_users")
  
  // Usage stats
  avgSessionsPerUser Float @default(0.0) @map("avg_sessions_per_user")
  avgMessagesPerUser Float @default(0.0) @map("avg_messages_per_user")
  
  // Flagged accounts
  flaggedUsers    Int      @default(0) @map("flagged_users")
  flaggedReasonCounts Json @default("{}") @map("flagged_reason_counts") // { "high_drift": 5, "low_engagement": 2 }
  
  // Outlier detection
  outlierWallets  Json     @default("[]") @map("outlier_wallets") // Array of wallet addresses with z-score > 2
  
  createdAt       DateTime @default(now()) @map("created_at")
  
  @@index([periodStart])
  @@map("memory_report_aggregates")
}

// ============================================
// Cross-App Agent Portability (v3.0.0) - Phase 1
// ============================================

enum AppTier {
  BASIC
  VERIFIED
  CERTIFIED
}

enum MemoryEntryType {
  PREFERENCE
  ACTION
  FACT
  CONVERSATION
}

// Registered third-party applications
model AgentApp {
  id            String   @id @default(uuid())
  appId        String   @unique // e.g., "notion", "slack", "linear"
  name         String
  description  String?
  iconUrl      String?  @map("icon_url")
  websiteUrl   String?  @map("website_url")
  
  // OAuth credentials
  redirectUris String[] @map("redirect_uris")
  appSecret   String   @map("app_secret") // hashed
  
  // Tier and status
  tier        AppTier  @default(BASIC)
  isActive    Boolean  @default(true)
  
  // Developer info
  developerEmail String? @map("developer_email")
  developerName  String? @map("developer_name")
  
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  // Relations
  permissions  AgentAppPermission[]
  sessions     AgentSession[]
  usageMetrics AppUsageMetric[]
  
  @@index([appId])
  @@index([tier])
  @@map("agent_apps")
}

// User permissions granted to apps (OAuth grants)
model AgentAppPermission {
  id            String   @id @default(uuid())
  walletAddress String   @map("wallet_address")
  appId         String   @map("app_id")
  app           AgentApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  
  // Scopes granted
  scopes        String[] // e.g., ["agent:identity:read", "agent:memory:write"]
  
  // OAuth tokens (encrypted)
  accessToken   String   @map("access_token") // encrypted
  refreshToken  String?  @map("refresh_token") // encrypted
  
  // Expiration
  expiresAt     DateTime @map("expires_at")
  
  // Status
  grantedAt     DateTime @default(now()) @map("granted_at")
  revokedAt     DateTime? @map("revoked_at")
  
  @@unique([walletAddress, appId])
  @@index([walletAddress])
  @@index([appId])
  @@map("agent_app_permissions")
}

// Cross-app agent sessions
model AgentSession {
  id             String   @id @default(uuid())
  sessionId      String   @unique @map("session_id")
  walletAddress  String   @map("wallet_address")
  appId          String   @map("app_id")
  app            AgentApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  
  // Session linking (for handoff)
  parentSessionId String? @map("parent_session_id") // If agent came from another app
  
  // Metadata
  userAgent     String?  @map("user_agent")
  ipAddress     String?  @map("ip_address")
  
  // Status
  startedAt     DateTime @default(now()) @map("started_at")
  lastActiveAt DateTime @updatedAt @map("last_active_at")
  endedAt       DateTime? @map("ended_at")
  
  // Relations
  messages      AgentSessionMessage[]
  
  @@index([walletAddress])
  @@index([appId])
  @@index([startedAt])
  @@map("agent_sessions")
}

// Session messages for context continuity
model AgentSessionMessage {
  id          String        @id @default(uuid())
  sessionId   String        @map("session_id")
  session    AgentSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  role        String        // "user", "assistant", "system"
  content     String
  appContext  Json?         @map("app_context") // App-specific metadata
  
  createdAt   DateTime      @default(now()) @map("created_at")
  
  @@index([sessionId])
  @@index([createdAt])
  @@map("agent_session_messages")
}

// Agent memory entries (learned context across apps)
model AgentMemoryEntry {
  id            String        @id @default(uuid())
  walletAddress String        @map("wallet_address")
  appId         String        @map("app_id")
  
  type          MemoryEntryType
  
  summary       String        // Brief description
  details       Json          // Structured data
  
  createdAt     DateTime      @default(now()) @map("created_at")
  
  @@index([walletAddress])
  @@index([appId])
  @@index([type])
  @@index([createdAt])
  @@map("agent_memory_entries")
}

// Usage metrics for billing
model AppUsageMetric {
  id                String     @id @default(uuid())
  appId             String     @map("app_id")
  app               AgentApp   @relation(fields: [appId], references: [id], onDelete: Cascade)
  walletAddress     String     @map("wallet_address")
  
  interactionType   String     @map("interaction_type") // "chat", "context_read", "memory_write"
  tokensUsed        Int        @default(0) @map("tokens_used")
  cost              Float      @default(0) // Calculated cost
  
  // Metadata
  sessionId         String?    @map("session_id")
  metadata          Json?
  
  timestamp         DateTime   @default(now()) @map("timestamp")
  
  @@index([appId])
  @@index([walletAddress])
  @@index([timestamp])
  @@index([appId, timestamp])
  @@map("app_usage_metrics")
}

// Enterprise organization config
model AgentAppOrganization {
  id              String   @id @default(uuid())
  orgId           String   @unique @map("org_id")
  name            String
  
  // Enterprise controls
  approvedApps    String[] @default([]) @map("approved_apps") // Whitelist
  blockedApps     String[] @default([]) @map("blocked_apps") // Blocklist
  requireApprovalFor String[] @default([]) @map("require_approval_for") // Scopes requiring approval
  
  // Admin
  adminWalletAddress String @map("admin_wallet_address")
  
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@index([orgId])
  @@index([adminWalletAddress])
  @@map("agent_app_organizations")
}

// OAuth Pending Authorization - stores in-progress OAuth flows in DB for persistence
model OAuthPendingAuthorization {
  id            String   @id @default(uuid())
  state         String   @unique // OAuth state parameter
  walletAddress String   @map("wallet_address")
  appId         String   @map("app_id")
  scopes        String[] // OAuth scopes requested
  redirectUri   String   @map("redirect_uri")
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([state])
  @@index([walletAddress])
  @@index([appId])
  @@index([expiresAt]) // For cleanup queries
  @@map("oauth_pending_authorizations")
}

// SDK API Key Challenge - stores pending API key creation challenges
model SDKAPIKeyChallenge {
  id            String   @id @default(uuid())
  challengeId   String   @unique @map("challenge_id")
  walletAddress String   @map("wallet_address")
  name          String
  permissions   String[]
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([challengeId])
  @@index([walletAddress])
  @@index([expiresAt])
  @@map("sdk_api_key_challenges")
}

// ============================================
// RCRT Integration Models
// ============================================

// RCRT Agent - Represents a provisioned RCRT agent
model RCRTAgent {
  id           String    @id @default(uuid())
  agentId      String    @unique @map("agent_id")
  ownerId      String    @map("owner_id")
  token        String    @map("token")
  status       String    @default("active")
  revoked      Boolean   @default(false)
  lastSeen     DateTime? @map("last_seen")
  provisionedAt DateTime @default(now()) @map("provisioned_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([ownerId])
  @@index([status])
  @@map("rcrt_agents")
}

// KB Registry - Tracks knowledge bases attached to RCRT
model KBRegistry {
  id               String    @id @default(uuid())
  kbId             String    @unique @map("kb_id")
  ownerId          String    @map("owner_id")
  appId            String?   @map("app_id")
  contextType      String    @default("public") @map("context_type")
  attachedAt       DateTime  @default(now()) @map("attached_at")
  excludedFromRCRT Boolean   @default(false) @map("excluded_from_rcrt")

  @@index([ownerId])
  @@index([kbId])
  @@map("kb_registries")
}

// KB Access History - Tracks KB access grants
model KBAccessHistory {
  id         String    @id @default(uuid())
  kbId       String    @map("kb_id")
  appId      String    @map("app_id")
  grantType  String    @map("grant_type")
  grantedAt  DateTime  @default(now()) @map("granted_at")
  revokedAt  DateTime? @map("revoked_at")

  @@index([kbId])
  @@index([appId])
  @@map("kb_access_history")
}

// Confidential Grant - Tracks confidential access grants
model ConfidentialGrant {
  id         String    @id @default(uuid())
  ownerId    String    @map("owner_id")
  appId      String    @map("app_id")
  grantedAt  DateTime  @default(now()) @map("granted_at")
  revokedAt  DateTime? @map("revoked_at")

  @@index([ownerId])
  @@index([appId])
  @@map("confidential_grants")
}

// Routing Log - Logs routing decisions
model RoutingLog {
  id           String   @id @default(uuid())
  ownerId      String   @map("owner_id")
  breadcrumbId String?  @map("breadcrumb_id")
  targetAppId  String?  @map("target_app_id")
  contextType  String?  @map("context_type")
  decision     String
  reason       String?
  timestamp    DateTime @default(now()) @map("timestamp")

  @@index([ownerId])
  @@index([breadcrumbId])
  @@index([targetAppId])
  @@index([timestamp])
  @@map("routing_logs")
}

// RCRT Audit Log - Comprehensive audit trail for RCRT operations
model RCRTAuditLog {
  id            String   @id @default(uuid())
  ownerId       String   @map("owner_id")
  
  // Action types: provision, revoke, connect, disconnect, sync, route, scan
  action        String   
  
  // Details
  agentId       String?  @map("agent_id")
  token         String?  // Masked - only first 8 chars stored
  status        String?  // success, failed, pending
  errorMessage  String?  @map("error_message")
  
  // Context
  contextType   String?  @map("context_type")
  targetAppId   String?  @map("target_app_id")
  breadcrumbId  String?  @map("breadcrumb_id")
  
  // Metadata
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  
  // Timing
  duration      Int?     // milliseconds
  
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([ownerId])
  @@index([action])
  @@index([agentId])
  @@index([status])
  @@index([createdAt])
  @@map("rcrt_audit_logs")
}
