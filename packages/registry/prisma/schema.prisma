generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Skill {
  id          String   @id @default(uuid())
  skillHash   String   @unique @map("skill_hash")
  name        String
  version     String
  description String?
  author      String   // Wallet address
  
  // IPFS CIDs
  manifestCid String   @map("manifest_cid")
  packageCid  String?  @map("package_cid")
  
  // On-chain data
  contractAddress String? @map("contract_address")
  tokenId         String? @map("token_id")
  
  // Metadata
  permissions   Json     // Stored as JSON
  trustScore    Float    @default(0) @map("trust_score")
  downloadCount Int      @default(0) @map("download_count")
  
  // Status
  status      SkillStatus @default(PENDING)
  isBlocked   Boolean     @default(false) @map("is_blocked")
  blockedAt   DateTime?   @map("blocked_at")
  blockedReason String?   @map("blocked_reason")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  audits    Audit[]
  categories SkillCategory[]
  tags      SkillTag[]
  
  @@index([skillHash])
  @@index([author])
  @@index([status])
  @@index([trustScore])
  @@map("skills")
}

model Audit {
  id          String   @id @default(uuid())
  skillId     String   @map("skill_id")
  skill       Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  
  auditor     String   // Wallet address
  auditorNft  String?  @map("auditor_nft") // NFT token ID
  
  status      AuditStatus
  findings    Json?    // Array of YARA findings
  signature   String   // Cryptographic signature
  
  // On-chain verification
  txHash      String?  @map("tx_hash")
  verifiedAt  DateTime? @map("verified_at")
  
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@index([skillId])
  @@index([auditor])
  @@index([status])
  @@map("audits")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  
  skills      SkillCategory[]
  
  @@map("categories")
}

model Tag {
  id    String @id @default(uuid())
  name  String @unique
  
  skills SkillTag[]
  
  @@map("tags")
}

model SkillCategory {
  skillId    String   @map("skill_id")
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  @@id([skillId, categoryId])
  @@map("skill_categories")
}

model SkillTag {
  skillId String @map("skill_id")
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  tagId   String @map("tag_id")
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@id([skillId, tagId])
  @@map("skill_tags")
}

// BLOCKER-1 FIX: Updated ApiKey model to match service implementation
model ApiKey {
  id          String    @id @default(uuid())
  keyHash     String    @unique @map("key_hash")
  walletAddress String  @map("wallet_address")
  name        String
  permissions String[]  // PostgreSQL array type
  
  // Rate limiting
  rateLimit   Int       @default(1000) @map("rate_limit")
  requestCount Int      @default(0) @map("request_count")
  
  // Status
  revokedAt   DateTime? @map("revoked_at")
  expiresAt   DateTime? @map("expires_at")
  
  createdAt   DateTime  @default(now()) @map("created_at")
  lastUsedAt  DateTime? @map("last_used_at")
  
  @@index([keyHash])
  @@index([walletAddress])
  @@map("api_keys")
}

// BLOCKER-1 FIX: New AuthNonce model for replay attack prevention
// Squad Epsilon MEDIUM-2 Fix: Added unique constraint to prevent duplicates
model AuthNonce {
  id            String   @id @default(uuid())
  walletAddress String   @map("wallet_address")
  nonce         String
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")
  
  @@unique([walletAddress, nonce])
  @@index([walletAddress])
  @@index([nonce])
  @@map("auth_nonces")
}

enum SkillStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum AuditStatus {
  SAFE
  SUSPICIOUS
  MALICIOUS
}

// BLOCKER-1 FIX: Removed old ApiTier enum (no longer used)

model SecurityScan {
  id          String   @id @default(uuid())
  skillHash   String   @map("skill_hash")
  
  severity    String   // 'safe', 'suspicious', 'malicious'
  findings    Json     // Array of YARA findings
  summary     Json     // Scan summary statistics
  
  scanDuration  Int    @map("scan_duration") // milliseconds
  scannedFiles  Int    @map("scanned_files")
  scannedBytes  Int    @map("scanned_bytes")
  
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@index([skillHash])
  @@index([severity])
  @@index([createdAt])
  @@map("security_scans")
}

// DEPLOYMENT FIX: TokenBlacklist model for JWT logout functionality
model TokenBlacklist {
  id            String   @id @default(uuid())
  tokenHash     String   @unique @map("token_hash")
  walletAddress String   @map("wallet_address")
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")
  
  @@index([tokenHash])
  @@index([walletAddress])
  @@map("token_blacklist")
}
