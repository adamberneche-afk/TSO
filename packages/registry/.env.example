# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/tais_registry?schema=public"

# IPFS Configuration
IPFS_ENABLED=true
IPFS_HOST=ipfs.infura.io
IPFS_PORT=5001
IPFS_PROTOCOL=https
IPFS_PROJECT_ID=your_infura_project_id
IPFS_PROJECT_SECRET=your_infura_project_secret

# Blockchain Configuration (Ethereum Mainnet)
# Get your API key from: https://www.alchemy.com or https://www.infura.io
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# OR use Cloudflare's free endpoint (no API key needed):
# RPC_URL=https://cloudflare-eth.com

# NFT Contract Addresses (Ethereum Mainnet)
# THINK Genesis Bundle NFT - already deployed
GENESIS_NFT_ADDRESS=0x11B3EfbF04F0bA505F380aC20444B6952970AdA6

# Publisher NFT - deploy your own or use Genesis
PUBLISHER_NFT_ADDRESS=0x11B3EfbF04F0bA505F380aC20444B6952970AdA6

# Auditor NFT - deploy your own or use Genesis  
AUDITOR_NFT_ADDRESS=0x11B3EfbF04F0bA505F380aC20444B6952970AdA6

# Staking Contract (already deployed)
STAKING_CONTRACT_ADDRESS=0x08071901A5C4D2950888Ce2b299bBd0e3087d101

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# AWS S3 (optional, for file backup)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Stripe (for fiat payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin Configuration
ADMIN_WALLET_ADDRESSES=0x123...,0x456...

# Testing (optional - for running blockchain tests)
# Set your wallet address to test NFT ownership
TEST_WALLET_ADDRESS=0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045

# Feature Flags
ENABLE_BLOCKCHAIN_VERIFICATION=false
ENABLE_IPFS_STORAGE=true
ENABLE_FIAT_PAYMENTS=false